// Integer square root, partial correctness.
vars int n, l, r, m;

pre { n >= 0 }

l = 0;
r = n + 1;

while (l != r - 1)
invariant { 0 <= l && l < r && l * l <= n && n < r * r }
{
  m = (l + r) / 2;
  if (m * m <= n) {
    l = m;
  } else {
    r = m;
  }
}

post { l * l <= n && n < (l + 1) * (l + 1) }
